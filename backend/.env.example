# Copy this file to .env for local development.
# .env is gitignored — never commit real values.

# ─── GCP ──────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# ─── Cloud Storage ────────────────────────────────────────────────────────────
GCS_BUCKET_NAME=your-project-id-documents-dev
# Folder prefix inside the bucket. Final path: {prefix}/{document_id}/{file}
GCS_UPLOAD_PREFIX=documents

# ─── Vertex AI ────────────────────────────────────────────────────────────────
VERTEX_MODEL_ID=gemini-1.5-pro-002
VERTEX_EMBEDDING_MODEL=text-embedding-004
# Max chunks per Vertex AI embedding API call (limit: 250)
EMBEDDING_BATCH_SIZE=100

# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]

# ─── Ingestion: file validation ────────────────────────────────────────────────
# Maximum upload size in megabytes
MAX_FILE_SIZE_MB=50

# ─── RAG: chunking ────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K=5

# ─── ChromaDB ─────────────────────────────────────────────────────────────────
# Local: relative path resolved from the backend/ directory
# Cloud Run: set to /tmp/chroma (ephemeral) or a mounted volume
CHROMA_PERSIST_DIR=data/chroma
CHROMA_COLLECTION_NAME=documents

# ─── Local development without GCS ────────────────────────────────────────────
# To test locally without a real GCS bucket:
#   Option 1: Use a real bucket + gcloud auth application-default login
#   Option 2: Run fake-gcs-server (Docker): docker run -p 4443:4443 fsouza/fake-gcs-server
#             Then set STORAGE_EMULATOR_HOST=http://localhost:4443
